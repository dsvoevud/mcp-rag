# ---------------------------------------------------------------------------
# .env.example — copy to .env and adjust values for your environment
#
# For local development:
#   cp .env.example .env
#   Start LM Studio, load a model, and enable the local server
#   (Settings -> Local Server -> Start Server, default port 1234).
#
# For Docker Compose:
#   The compose file sets LLM_BASE_URL=http://host.docker.internal:1234/v1
#   so the container reaches LM Studio running on your host machine.
#   Override LLM_MODEL here if you want to use a different loaded model.
# ---------------------------------------------------------------------------

# ---- LLM (LM Studio) ----------------------------------------------------
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=deepseek/deepseek-r1-0528-qwen3-8b
LLM_TEMPERATURE=0.0
# Strip <think>...</think> tags emitted by DeepSeek R1 models
LLM_STRIP_THINKING_TAGS=true

# ---- Embeddings ----------------------------------------------------------
EMBEDDING_PROVIDER=default   # "default" (in-process) | "ollama"
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ---- Chunking ------------------------------------------------------------
CHUNK_SIZE=600
CHUNK_OVERLAP=80

# ---- Vector store --------------------------------------------------------
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=rag_collection

# ---- Retrieval -----------------------------------------------------------
TOP_K=5

# ---- Corrective RAG graph ------------------------------------------------
MAX_RETRIEVE_RETRIES=2
MAX_GENERATE_RETRIES=1

# ---- MCP server transport ------------------------------------------------
# stdio            — default; used by Claude Desktop / MCP clients
# streamable-http  — HTTP server (used by docker-compose.yml)
TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
